---
import eventData from '../data/event.json';
---
<nav class="nav">
  <div class="nav-logo">THE BATCH</div>
  <div class="nav-links">
    <span>How it works</span>
    <span>Past batches</span>
    <span>About</span>
  </div>
  <a
    href={eventData.lumaUrl}
    class="nav-book"
    target="_blank"
    rel="noopener"
    data-umami-event="book_cta_click"
    data-umami-event-location="nav"
  >Book a seat →</a>
</nav>

<style>
  .nav {
    padding: 24px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: sticky;
    top: 0;
    background: var(--bg-pink);
    z-index: 100;
  }

  .nav-logo {
    font-family: 'Titan One', sans-serif;
    font-size: 22px;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--ink);
    line-height: 1;
  }

  .nav-links {
    display: flex;
    gap: 28px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
  }

  .nav-links span {
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .nav-links span:hover {
    opacity: 0.6;
  }

  .nav-book {
    background: var(--ink);
    color: var(--cream);
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 600;
    padding: 10px 20px;
    border-radius: 40px;
    text-decoration: none;
  }
</style>
