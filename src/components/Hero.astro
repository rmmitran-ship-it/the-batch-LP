---
import eventData from '../data/event.json';
import Ribbon from './Ribbon.astro';
---
<section class="hero">
  <h1 class="hero-logo">
    <span class="line">THE</span>
    <span class="line">BATCH</span>
  </h1>
  <p class="hero-manifesto">
    It's just people cooking together. <em>Like we used to.</em>
  </p>
  <p class="hero-ps">
    <strong>PS</strong>this is not a cooking class.
  </p>
  <a
    href={eventData.lumaUrl}
    class="hero-cta"
    target="_blank"
    rel="noopener"
    data-umami-event="book_cta_click"
    data-umami-event-location="hero"
  >Book the next batch <span>→</span></a>
  <Ribbon />
</section>

<style>
  .hero {
    min-height: 85vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 24px 0;
    text-align: center;
    overflow: hidden;
  }

  .hero-logo {
    font-family: 'Titan One', sans-serif;
    font-size: clamp(96px, 18vw, 260px);
    line-height: 0.85;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--hot-orange);
    margin-bottom: 48px;
  }

  .hero-logo .line {
    display: block;
  }

  .hero-manifesto {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: clamp(22px, 3vw, 34px);
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--ink);
    max-width: 780px;
    margin-bottom: 20px;
  }

  .hero-manifesto em {
    font-style: italic;
    color: var(--burgundy);
  }

  .hero-ps {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: clamp(14px, 1.4vw, 17px);
    color: var(--ink-soft);
    margin-bottom: 48px;
    max-width: 600px;
  }

  .hero-ps strong {
    font-family: 'Inter', sans-serif;
    font-style: normal;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--burgundy);
    margin-right: 8px;
  }

  .hero-cta {
    background: var(--lime);
    color: var(--ink);
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: clamp(15px, 1.2vw, 17px);
    padding: 14px 30px;
    border-radius: 60px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border: 2px solid var(--ink);
    transition: transform 0.2s, background 0.2s;
    margin-bottom: 36px;
  }

  .hero-cta:hover {
    background: var(--lime-dark);
    transform: translateY(-2px);
  }
</style>
